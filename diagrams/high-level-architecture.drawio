        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;flowchart TD\n\n%% =========================\n%% TITLE\n%% =========================\n\nA[\&quot;🏭 SafeFusion AI&lt;br/&gt;&lt;b&gt;AI-Powered Industrial Safety Intelligence Platform&lt;/b&gt;\&quot;]\n\n%% =========================\n%% DATA SOURCES\n%% =========================\n\nsubgraph DS[\&quot;DATA SOURCES\&quot;]\n\nIOT[\&quot;📡 IoT Sensors\&quot;]\nSCADA[\&quot;⚙️ SCADA Systems\&quot;]\nPERMIT[\&quot;📋 Permit-to-Work System\&quot;]\nMAIN[\&quot;🔧 Maintenance Logs\&quot;]\nCCTV[\&quot;📷 CCTV Cameras\&quot;]\nWORKER[\&quot;👷 Worker Tracking\&quot;]\nINCIDENT[\&quot;📄 Historical Incident Reports\&quot;]\nREG[\&quot;📚 Safety Regulations&lt;br/&gt;(OISD / Factory Act / DGMS)\&quot;]\n\nend\n\n%% =========================\n%% DATA INGESTION\n%% =========================\n\nsubgraph DI[\&quot;DATA INGESTION LAYER\&quot;]\n\nAPI[\&quot;REST APIs\&quot;]\nWS[\&quot;WebSockets\&quot;]\nVALID[\&quot;Data Validation\&quot;]\nNORMAL[\&quot;Data Normalization\&quot;]\n\nend\n\n%% =========================\n%% DATA MANAGEMENT\n%% =========================\n\nsubgraph DB[\&quot;DATA MANAGEMENT\&quot;]\n\nPOSTGRES[\&quot;🗄 PostgreSQL\n\n• Workers\n• Sensors\n• Permits\n• Maintenance\n• Alerts\&quot;]\n\nNEO4J[\&quot;🕸 Neo4j\n\nKnowledge Graph\n\n• Workers\n• Equipment\n• Permits\n• Relationships\&quot;]\n\nVECTOR[\&quot;🧠 pgvector\n\n• Embeddings\n• Semantic Search\n• RAG Storage\&quot;]\n\nend\n\n%% =========================\n%% AI LAYER\n%% =========================\n\nsubgraph AI[\&quot;AI INTELLIGENCE LAYER\&quot;]\n\nSUP[\&quot;🤖 Supervisor Agent\&quot;]\n\nsubgraph AGENTS[\&quot;Specialized AI Agents\&quot;]\n\nSENSOR[\&quot;Sensor Intelligence Agent\&quot;]\n\nPERMITA[\&quot;Permit Intelligence Agent\&quot;]\n\nCV[\&quot;Computer Vision Agent\&quot;]\n\nCOMP[\&quot;Compliance Agent\&quot;]\n\nINC[\&quot;Incident Intelligence Agent\&quot;]\n\nend\n\nend\n\n%% =========================\n%% RISK ENGINE\n%% =========================\n\nsubgraph RISK[\&quot;COMPOUND RISK ENGINE\&quot;]\n\nCORR[\&quot;Multi-source Event Correlation\&quot;]\n\nSCORE[\&quot;Risk Scoring\&quot;]\n\nPRED[\&quot;Predictive Analytics\&quot;]\n\nXAI[\&quot;Explainable AI Recommendations\&quot;]\n\nend\n\n%% =========================\n%% OUTPUTS\n%% =========================\n\nsubgraph OUT[\&quot;OUTPUTS\&quot;]\n\nDASH[\&quot;📊 Industrial Dashboard\&quot;]\n\nMAP[\&quot;🗺 Geospatial Safety Heatmap\&quot;]\n\nCOPILOT[\&quot;💬 AI Safety Copilot\&quot;]\n\nALERT[\&quot;🚨 Real-time Alerts\&quot;]\n\nREPORT[\&quot;📑 Incident Reports\&quot;]\n\nER[\&quot;🚑 Emergency Response Orchestrator\&quot;]\n\nend\n\n%% =========================\n%% FLOW\n%% =========================\n\nA --&gt; DS\n\nIOT --&gt; API\nSCADA --&gt; API\nPERMIT --&gt; API\nMAIN --&gt; API\nCCTV --&gt; API\nWORKER --&gt; API\nINCIDENT --&gt; API\nREG --&gt; API\n\nAPI --&gt; WS\nWS --&gt; VALID\nVALID --&gt; NORMAL\n\nNORMAL --&gt; POSTGRES\nNORMAL --&gt; NEO4J\nNORMAL --&gt; VECTOR\n\nPOSTGRES --&gt; SUP\nNEO4J --&gt; SUP\nVECTOR --&gt; SUP\n\nSUP --&gt; SENSOR\nSUP --&gt; PERMITA\nSUP --&gt; CV\nSUP --&gt; COMP\nSUP --&gt; INC\n\nSENSOR --&gt; CORR\nPERMITA --&gt; CORR\nCV --&gt; CORR\nCOMP --&gt; CORR\nINC --&gt; CORR\n\nCORR --&gt; SCORE\nSCORE --&gt; PRED\nPRED --&gt; XAI\n\nXAI --&gt; DASH\nXAI --&gt; MAP\nXAI --&gt; COPILOT\nXAI --&gt; ALERT\nXAI --&gt; REPORT\nXAI --&gt; ER\n\n%% =========================\n%% COLORS\n%% =========================\n\nstyle DS fill:#DBEAFE,stroke:#2563EB,stroke-width:2px\nstyle DI fill:#CFFAFE,stroke:#06B6D4,stroke-width:2px\nstyle DB fill:#EDE9FE,stroke:#7C3AED,stroke-width:2px\nstyle AI fill:#DCFCE7,stroke:#16A34A,stroke-width:2px\nstyle RISK fill:#FEF3C7,stroke:#F59E0B,stroke-width:2px\nstyle OUT fill:#FEE2E2,stroke:#DC2626,stroke-width:2px\n\nstyle SUP fill:#22C55E,color:#fff,stroke:#166534,stroke-width:2px\nstyle CORR fill:#F59E0B,color:#fff\nstyle SCORE fill:#F59E0B,color:#fff\nstyle PRED fill:#F59E0B,color:#fff\nstyle XAI fill:#F59E0B,color:#fff&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="JreB5U8nlgTbi9edp6pV-1">
