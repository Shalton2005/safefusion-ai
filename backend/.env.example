# ── Application ───────────────────────────────────────────────────────────────
PROJECT_NAME=SafeFusion AI
PROJECT_VERSION=1.0.0
DEBUG=false
API_PREFIX=/api/v1

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/safefusion_db

# ── Neo4j (Knowledge Graph) ──────────────────────────────────────────────────
# Independent of PostgreSQL — reserved for future knowledge-graph queries.
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=change-this-password-in-production
NEO4J_DATABASE=neo4j

# ── Security ──────────────────────────────────────────────────────────────────
# Replace with a strong, randomly generated value before deploying.
SECRET_KEY=change-this-to-a-strong-random-secret-key

# ── CORS ──────────────────────────────────────────────────────────────────────
# JSON array of allowed origins.
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8080"]
