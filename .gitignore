# AI and ML artifacts
# Anchored to the repo root (leading `/`) so these only match top-level
# artifact directories — an unanchored `models/` also matched
# backend/src/models/ (the ORM models package), silently excluding it
# from version control.
/artifacts/
/checkpoints/
/models/
/weights/
/wandb/
/mlruns/

